                </button>
              ))}
            </div>
          </div>

          <div className="flex gap-4 pt-4">
            <button
              onClick={onClose}
              className="flex-1 py-3 rounded-xl border border-white/20 text-white text-lg font-extralight hover:bg-white/5 transition-colors"
            >
              {t("teacher.cancel")}
            </button>
            <motion.button
              whileHover={{ scale: 1.02 }}
              whileTap={{ scale: 0.98 }}
