export const generateMockVotes = () => {
  const votes = [];
  const demographics = ["M", "F"];
  const ages = [15, 16, 17, 18];
  mockSessions.forEach((session) => {
    const voteCount = Math.floor(Math.random() * 25) + 10;
    for (let i = 0; i < voteCount; i++) {
      votes.push({
        id: `vote-${session.id}-${i}`,
        sessionId: session.id,
        candidateId: session.candidates[Math.floor(Math.random() * session.candidates.length)],
        timestamp: new Date(Date.now() - Math.random() * 86400000 * 7).toISOString(),
        demographics: {
          gender: demographics[Math.floor(Math.random() * demographics.length)],
          age: ages[Math.floor(Math.random() * ages.length)]
        }
      });
    }
  });
  return votes;
};

